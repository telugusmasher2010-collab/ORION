{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "ORION",
  "version": "3.0.0",
  "identifier": "com.orion.desktop",
  "build": {
    "frontendDist": "../UI",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "ORION",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": false,
        "transparent": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "resources": {
      "../CORE/http-bridge.js": "CORE/http-bridge.js",
      "../CORE/systems_rules.md.txt": "CORE/systems_rules.md.txt",
      "../PROMPTS/master_prompt.md.txt": "PROMPTS/master_prompt.md.txt",
      "../PROMPTS/startup_prompt.md.txt": "PROMPTS/startup_prompt.md.txt",
      "../CONFIG/constraints.md.txt": "CONFIG/constraints.md.txt",
      "../CONFIG/modes.json": "CONFIG/modes.json",
      "../MEMORY/long_term_memory.md.txt": "MEMORY/long_term_memory.md.txt"
    }
  }
}
