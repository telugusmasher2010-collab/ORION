/* ============================================================
   ORION 3.0 — Vercel-Inspired Monochrome Theme
   
   Design system: near-black background (#0a0a0a), high-contrast
   monochrome palette (#e5e5e5 text, #222 borders), Inter font,
   1px sharp borders, subtle grid background pattern, small
   border-radius (6-8px), precise spacing throughout.
   
   Inspired by Vercel's clean, typographic simplicity.
   ============================================================ */

/* ── CSS Custom Properties ── */
:root {
    /* Background colors — near-black spectrum */
    --bg-primary: #0a0a0a;
    --bg-secondary: #111111;
    --bg-tertiary: #181818;
    --bg-card: #141414;
    --bg-surface: rgba(255, 255, 255, 0.03);
    --bg-input: #0d0d0d;
    --bg-elevated: #1a1a1a;

    /* Text colors — high contrast monochrome */
    --text-primary: #e5e5e5;
    --text-secondary: #888888;
    --text-muted: #555555;
    --text-accent: #ffffff;

    /* Border colors — sharp 1px */
    --border-subtle: #222222;
    --border-active: #e5e5e5;
    --border-hover: #444444;

    /* Accent — restrained, monochrome */
    --accent-primary: #ffffff;
    --accent-secondary: #999999;
    --accent-glow: rgba(255, 255, 255, 0.08);

    /* Semantic colors */
    --success: #22c55e;
    --warning: #f59e0b;
    --error: #ef4444;
    --info: #3b82f6;

    /* Typography */
    --font-main: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    --font-mono: 'JetBrains Mono', 'Cascadia Code', 'Fira Code', 'Consolas', monospace;

    /* Border radius — small and consistent */
    --radius-sm: 6px;
    --radius-md: 8px;
    --radius-lg: 12px;

    /* Layout dimensions */
    --sidebar-collapsed: 52px;
    --sidebar-expanded: 180px;
    --right-panel-width: 240px;
    --titlebar-height: 40px;

    /* Shadows — subtle, no color glow */
    --shadow-card: 0 1px 2px rgba(0, 0, 0, 0.3);
    --shadow-elevated: 0 4px 16px rgba(0, 0, 0, 0.4);
    --shadow-modal: 0 20px 60px rgba(0, 0, 0, 0.6);
}

/* ── Reset & Base ── */
*, *::before, *::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

html, body {
    height: 100%;
    overflow: hidden;
    background: var(--bg-primary);
    color: var(--text-primary);
    font-family: var(--font-main);
    font-size: 13px;
    line-height: 1.5;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
}

/* Subtle grid background pattern — Vercel-style */
body::before {
    content: '';
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-image:
        linear-gradient(rgba(255, 255, 255, 0.02) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255, 255, 255, 0.02) 1px, transparent 1px);
    background-size: 32px 32px;
    pointer-events: none;
    z-index: 0;
}

/* ── Custom Scrollbar ── */
::-webkit-scrollbar {
    width: 5px;
    height: 5px;
}

::-webkit-scrollbar-track {
    background: transparent;
}

::-webkit-scrollbar-thumb {
    background: #333;
    border-radius: 3px;
}

::-webkit-scrollbar-thumb:hover {
    background: #555;
}

/* ── Utility Classes ── */
.hidden {
    display: none !important;
}

/* ── Title Bar ── */
#titlebar {
    height: var(--titlebar-height);
    background: var(--bg-secondary);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 8px 0 12px;
    border-bottom: 1px solid var(--border-subtle);
    -webkit-app-region: drag;
    user-select: none;
    z-index: 100;
    position: relative;
}

#titlebar-drag {
    display: flex;
    align-items: center;
    gap: 10px;
}

.logo-icon {
    font-size: 18px;
    color: var(--text-primary);
    opacity: 0.9;
}

.titlebar-logo {
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 2px;
    color: var(--text-primary);
}

.mode-badge {
    font-size: 10px;
    padding: 2px 10px;
    border-radius: 20px;
    background: var(--bg-tertiary);
    border: 1px solid var(--border-subtle);
    color: var(--text-muted);
    -webkit-app-region: no-drag;
}

#titlebar-controls {
    display: flex;
    -webkit-app-region: no-drag;
    gap: 2px;
}

.titlebar-btn {
    width: 36px;
    height: var(--titlebar-height);
    border: none;
    background: transparent;
    color: var(--text-muted);
    font-size: 11px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s, color 0.15s;
    border-radius: 0;
}

.titlebar-btn:hover {
    background: rgba(255, 255, 255, 0.06);
    color: var(--text-primary);
}

.titlebar-btn.btn-close:hover {
    background: var(--error);
    color: #fff;
}

/* ── Status Indicator ── */
.status-indicator {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 2px 10px;
    border-radius: 12px;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.3px;
    -webkit-app-region: no-drag;
}

.status-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--success);
    box-shadow: 0 0 4px var(--success);
    animation: statusPulse 2s ease-in-out infinite;
}

.status-text {
    color: inherit;
    opacity: 0.9;
}

.status-indicator.status-online {
    background: rgba(34, 197, 94, 0.08);
    color: var(--success);
}

.status-indicator.status-processing {
    background: rgba(245, 158, 11, 0.08);
    color: var(--warning);
}

.status-indicator.status-processing .status-dot {
    background: var(--warning);
    box-shadow: 0 0 4px var(--warning);
    animation: spin 1s linear infinite;
}

.status-indicator.status-listening {
    background: rgba(59, 130, 246, 0.08);
    color: var(--info);
}

.status-indicator.status-listening .status-dot {
    background: var(--info);
    box-shadow: 0 0 4px var(--info);
}

.status-indicator.status-speaking {
    background: rgba(255, 255, 255, 0.08);
    color: var(--text-primary);
}

.status-indicator.status-speaking .status-dot {
    background: var(--text-primary);
    box-shadow: 0 0 4px rgba(255, 255, 255, 0.3);
}

@keyframes statusPulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
}

@keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
}

/* ── App Layout ── */
.app-layout {
    display: flex;
    height: calc(100vh - var(--titlebar-height));
    overflow: hidden;
    position: relative;
    z-index: 1;
}

/* ── Left Sidebar ── */
.sidebar-left {
    width: var(--sidebar-collapsed);
    min-width: var(--sidebar-collapsed);
    background: var(--bg-secondary);
    display: flex;
    flex-direction: column;
    transition: width 0.2s ease, min-width 0.2s ease;
    position: relative;
    z-index: 10;
    overflow: hidden;
    border-right: 1px solid var(--border-subtle);
}

.sidebar-left.expanded {
    width: var(--sidebar-expanded);
    min-width: var(--sidebar-expanded);
}

.sidebar-nav {
    flex: 1;
    padding: 8px 6px;
    overflow-y: auto;
    overflow-x: hidden;
    display: flex;
    flex-direction: column;
    gap: 2px;
}

/* ── Navigation Items ── */
.nav-item {
    display: flex;
    align-items: center;
    gap: 10px;
    width: 100%;
    padding: 0;
    height: 40px;
    border: none;
    background: transparent;
    color: var(--text-muted);
    font-size: 13px;
    font-family: var(--font-main);
    cursor: pointer;
    border-radius: var(--radius-sm);
    text-align: left;
    transition: background 0.15s, color 0.15s;
    position: relative;
    white-space: nowrap;
    overflow: hidden;
    flex-shrink: 0;
}

.nav-item .nav-icon {
    width: 40px;
    min-width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
    flex-shrink: 0;
}

.nav-item .nav-text {
    opacity: 0;
    transition: opacity 0.15s;
    overflow: hidden;
    text-overflow: ellipsis;
    font-size: 13px;
    font-weight: 400;
}

.sidebar-left.expanded .nav-item .nav-text {
    opacity: 1;
}

.nav-item:hover {
    background: rgba(255, 255, 255, 0.04);
    color: var(--text-secondary);
}

.nav-item.active {
    color: var(--text-primary);
    background: rgba(255, 255, 255, 0.06);
}

.nav-item.active::before {
    content: '';
    position: absolute;
    left: 0;
    top: 8px;
    bottom: 8px;
    width: 2px;
    background: var(--text-primary);
    border-radius: 0 2px 2px 0;
}

/* Tooltip on collapsed sidebar */
.sidebar-left.collapsed .nav-item::after {
    content: attr(data-tooltip);
    position: absolute;
    left: calc(100% + 8px);
    top: 50%;
    transform: translateY(-50%);
    background: var(--bg-elevated);
    color: var(--text-primary);
    padding: 4px 10px;
    border-radius: var(--radius-sm);
    font-size: 11px;
    white-space: nowrap;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.15s;
    z-index: 100;
    border: 1px solid var(--border-subtle);
    box-shadow: var(--shadow-elevated);
}

.sidebar-left.collapsed .nav-item:hover::after {
    opacity: 1;
}

/* ── Sidebar Footer ── */
.sidebar-footer {
    padding: 8px 6px;
    border-top: 1px solid var(--border-subtle);
    display: flex;
    align-items: center;
    gap: 10px;
    height: 48px;
    overflow: hidden;
}

.sidebar-bottom {
    border-top: 1px solid var(--border-subtle);
    flex-shrink: 0;
}

/* ── User Avatar ── */
.user-avatar {
    width: 32px;
    min-width: 32px;
    height: 32px;
    background: var(--bg-tertiary);
    border: 1px solid var(--border-subtle);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 500;
    font-size: 12px;
    color: var(--text-primary);
    margin-left: 4px;
    flex-shrink: 0;
}

.user-name {
    font-size: 12px;
    color: var(--text-secondary);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    opacity: 0;
    transition: opacity 0.15s;
}

.sidebar-left.expanded .user-name {
    opacity: 1;
}

/* ── Sidebar Toggle ── */
.sidebar-toggle {
    width: 100%;
    height: 32px;
    border: none;
    background: transparent;
    color: var(--text-muted);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 10px;
    transition: background 0.15s, color 0.15s;
    flex-shrink: 0;
    border-top: 1px solid var(--border-subtle);
}

.sidebar-toggle:hover {
    background: rgba(255, 255, 255, 0.04);
    color: var(--text-secondary);
}

.toggle-icon {
    display: inline-block;
    transition: transform 0.2s ease;
    font-size: 10px;
}

.sidebar-left.expanded .toggle-icon {
    transform: rotate(180deg);
}

/* ── Dividers ── */
.divider {
    width: 4px;
    cursor: col-resize;
    background: transparent;
    position: relative;
    flex-shrink: 0;
    z-index: 5;
    transition: background 0.15s;
}

.divider:hover,
.divider.dragging {
    background: var(--text-muted);
    opacity: 0.5;
}

.divider.hidden {
    display: none;
}

/* ── Center Panel ── */
.center-panel {
    flex: 1;
    display: flex;
    flex-direction: column;
    min-width: 300px;
    overflow: hidden;
    background: var(--bg-primary);
}

/* ── View Container ── */
.view-container {
    flex: 1;
    min-height: 0;
    overflow-y: auto;
    padding: 24px 28px;
}

.view {
    display: none;
    flex-direction: column;
    height: 100%;
}

.view.active {
    display: flex;
}

.view.hidden {
    display: none !important;
}

.view-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20px;
    flex-shrink: 0;
}

.view-header h2 {
    font-size: 18px;
    font-weight: 600;
    color: var(--text-primary);
    letter-spacing: -0.02em;
}

.view-header-left {
    display: flex;
    align-items: center;
    gap: 12px;
}

/* ── Buttons ── */
.btn-primary {
    padding: 8px 16px;
    background: var(--text-primary);
    color: var(--bg-primary);
    border: none;
    border-radius: var(--radius-sm);
    font-size: 12px;
    font-weight: 500;
    font-family: var(--font-main);
    cursor: pointer;
    transition: opacity 0.15s, transform 0.15s;
    letter-spacing: 0.01em;
}

.btn-primary:hover {
    opacity: 0.85;
}

.btn-primary:active {
    transform: scale(0.98);
}

.btn-secondary {
    padding: 8px 16px;
    background: transparent;
    color: var(--text-secondary);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-sm);
    font-size: 12px;
    font-family: var(--font-main);
    cursor: pointer;
    transition: border-color 0.15s, color 0.15s;
}

.btn-secondary:hover {
    border-color: var(--border-hover);
    color: var(--text-primary);
}

.btn-back {
    padding: 6px 12px;
    background: transparent;
    color: var(--text-muted);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-sm);
    font-size: 12px;
    font-family: var(--font-main);
    cursor: pointer;
    transition: border-color 0.15s, color 0.15s;
}

.btn-back:hover {
    color: var(--text-primary);
    border-color: var(--border-hover);
}

/* ── Dashboard (Plain Start) ── */
.dashboard-plain {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 100%;
    gap: 36px;
    padding: 20px;
}

.dashboard-hero {
    text-align: center;
}

.hero-icon {
    font-size: 48px;
    color: var(--text-primary);
    opacity: 0.8;
    margin-bottom: 12px;
    animation: heroGlow 3s ease-in-out infinite;
}

@keyframes heroGlow {
    0%, 100% { opacity: 0.8; transform: scale(1); }
    50% { opacity: 1; transform: scale(1.05); }
}

.dashboard-hero h1 {
    font-size: 36px;
    font-weight: 700;
    letter-spacing: 4px;
    color: var(--text-primary);
    margin-bottom: 8px;
}

.hero-sub {
    font-size: 14px;
    color: var(--text-muted);
    font-weight: 400;
}

.dashboard-quick {
    display: flex;
    gap: 12px;
}

.quick-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    padding: 20px 28px;
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-md);
    cursor: pointer;
    font-family: var(--font-main);
    transition: border-color 0.2s, background 0.2s, transform 0.15s;
    min-width: 150px;
}

.quick-card:hover {
    border-color: var(--text-muted);
    background: var(--bg-surface);
    transform: translateY(-1px);
}

.qc-icon {
    font-size: 24px;
    opacity: 0.9;
}

.qc-title {
    font-size: 13px;
    font-weight: 600;
    color: var(--text-primary);
}

.qc-desc {
    font-size: 11px;
    color: var(--text-muted);
    text-align: center;
    line-height: 1.4;
}

/* ── Dashboard Stats ── */
.dashboard-stats {
    display: flex;
    gap: 24px;
}

.mini-stat {
    text-align: center;
}

.ms-value {
    display: block;
    font-size: 26px;
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1.2;
}

.ms-label {
    display: block;
    font-size: 11px;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-top: 4px;
}

/* ── Recent Sessions (Dashboard) ── */
.dashboard-recent {
    width: 100%;
    max-width: 480px;
}

.dashboard-recent h3 {
    font-size: 11px;
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 10px;
    text-align: center;
}

.recent-sessions-list {
    display: flex;
    flex-direction: column;
    gap: 6px;
}

.recent-session-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 14px;
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition: border-color 0.15s, background 0.15s;
}

.recent-session-item:hover {
    border-color: var(--border-hover);
    background: var(--bg-surface);
}

.recent-session-title {
    font-size: 13px;
    font-weight: 500;
    color: var(--text-primary);
}

.recent-session-time {
    font-size: 11px;
    color: var(--text-muted);
}

/* ── Projects Grid ── */
.projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 12px;
}

.project-card {
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-md);
    padding: 16px;
    cursor: pointer;
    transition: border-color 0.2s, background 0.2s;
}

.project-card:hover {
    border-color: var(--border-hover);
    background: var(--bg-surface);
}

.project-card.selected {
    border-color: var(--text-primary);
    background: rgba(255, 255, 255, 0.04);
}

.project-card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 8px;
}

.project-card-name {
    font-size: 15px;
    font-weight: 600;
    color: var(--text-primary);
}

.project-card-count {
    font-size: 11px;
    color: var(--text-muted);
    background: var(--bg-tertiary);
    padding: 2px 8px;
    border-radius: 10px;
    border: 1px solid var(--border-subtle);
}

.project-card-desc {
    font-size: 12px;
    color: var(--text-secondary);
    margin-bottom: 8px;
    line-height: 1.4;
}

.project-card-meta {
    font-size: 11px;
    color: var(--text-muted);
}

/* ── Sessions List (Project Detail) ── */
.sessions-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
}

.session-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 16px;
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition: border-color 0.15s, background 0.15s;
}

.session-card:hover {
    border-color: var(--border-hover);
    background: var(--bg-surface);
}

.session-card.selected {
    border-color: var(--text-primary);
    background: rgba(255, 255, 255, 0.04);
}

.session-card-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
}

.session-card-title {
    font-size: 13px;
    font-weight: 500;
    color: var(--text-primary);
}

.session-card-meta {
    font-size: 11px;
    color: var(--text-muted);
}

.session-card-actions {
    display: flex;
    gap: 4px;
    opacity: 0;
    transition: opacity 0.15s;
}

.session-card:hover .session-card-actions {
    opacity: 1;
}

.session-card-actions button {
    width: 28px;
    height: 28px;
    border: none;
    background: transparent;
    color: var(--text-muted);
    cursor: pointer;
    border-radius: 4px;
    font-size: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s, color 0.15s;
}

.session-card-actions button:hover {
    background: rgba(255, 255, 255, 0.06);
    color: var(--text-primary);
}

.session-card-actions button.delete-btn:hover {
    background: rgba(239, 68, 68, 0.12);
    color: var(--error);
}

.delete-btn {
    font-size: 12px;
}

/* ── Chat Section ── */
.chat-section {
    display: flex;
    flex-direction: column;
    min-height: 180px;
    max-height: 50%;
    flex-shrink: 0;
}

.chat-divider {
    height: 6px;
    cursor: row-resize;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: background 0.15s;
    background: transparent;
}

.chat-divider:hover {
    background: rgba(255, 255, 255, 0.04);
}

.chat-divider-handle {
    width: 40px;
    height: 3px;
    background: var(--border-subtle);
    border-radius: 2px;
    transition: background 0.15s;
}

.chat-divider:hover .chat-divider-handle {
    background: var(--text-muted);
}

.chat-area {
    flex: 1;
    display: flex;
    flex-direction: column;
    min-height: 0;
    background: var(--bg-secondary);
    border-top: 1px solid var(--border-subtle);
    border-radius: var(--radius-md) var(--radius-md) 0 0;
    overflow: hidden;
}

#messages-container {
    flex: 1;
    min-height: 0;
    overflow-y: auto;
    padding: 16px 20px;
}

#messages {
    max-width: 800px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 12px;
}

/* ── Messages ── */
.message {
    display: flex;
    gap: 10px;
    animation: msgIn 0.2s ease;
}

@keyframes msgIn {
    from { opacity: 0; transform: translateY(6px); }
    to { opacity: 1; transform: translateY(0); }
}

.message-avatar {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 11px;
    flex-shrink: 0;
    margin-top: 2px;
}

.orion-message .message-avatar {
    background: var(--bg-tertiary);
    border: 1px solid var(--border-subtle);
    color: var(--text-primary);
    font-weight: 600;
}

.user-message {
    flex-direction: row-reverse;
}

.user-message .message-avatar {
    background: var(--bg-elevated);
    border: 1px solid var(--border-subtle);
    color: var(--text-primary);
    font-weight: 500;
}

.message-body {
    max-width: 75%;
    min-width: 0;
}

.message-header {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 4px;
}

.user-message .message-header {
    flex-direction: row-reverse;
}

.message-author {
    font-size: 11px;
    font-weight: 600;
    color: var(--text-primary);
    letter-spacing: 0.3px;
}

.user-message .message-author {
    color: var(--text-secondary);
}

.message-meta {
    font-size: 10px;
    color: var(--text-muted);
    font-family: var(--font-mono);
}

.message-content {
    padding: 10px 14px;
    border-radius: var(--radius-md);
    font-size: 13px;
    line-height: 1.65;
    color: var(--text-primary);
    word-wrap: break-word;
    white-space: pre-wrap;
}

.orion-message .message-content {
    background: var(--bg-tertiary);
    border: 1px solid var(--border-subtle);
    border-top-left-radius: 4px;
}

.user-message .message-content {
    background: var(--bg-surface);
    border: 1px solid var(--border-subtle);
    border-top-right-radius: 4px;
}

/* Code blocks in messages */
.message-content code {
    background: rgba(0, 0, 0, 0.4);
    padding: 1px 5px;
    border-radius: 3px;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--text-primary);
}

.message-content pre {
    background: rgba(0, 0, 0, 0.4);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-sm);
    padding: 12px;
    overflow-x: auto;
    margin: 8px 0;
}

.message-content pre code {
    background: none;
    padding: 0;
    color: var(--text-primary);
    font-size: 12px;
    line-height: 1.5;
}

/* Streaming indicator dots */
.streaming-dots {
    display: inline-flex;
    gap: 4px;
    padding: 4px 0;
}

.streaming-dots .dot {
    width: 6px;
    height: 6px;
    background: var(--text-muted);
    border-radius: 50%;
    animation: dotPulse 1.2s ease-in-out infinite;
}

.streaming-dots .dot:nth-child(2) {
    animation-delay: 0.2s;
}

.streaming-dots .dot:nth-child(3) {
    animation-delay: 0.4s;
}

@keyframes dotPulse {
    0%, 100% { opacity: 0.3; transform: scale(0.8); }
    50% { opacity: 1; transform: scale(1.2); }
}

/* ── Input Area ── */
.input-wrapper {
    display: flex;
    align-items: flex-end;
    gap: 8px;
    padding: 10px 16px;
    border-top: 1px solid var(--border-subtle);
    background: var(--bg-input);
}

#message-input {
    flex: 1;
    background: transparent;
    border: none;
    outline: none;
    color: var(--text-primary);
    font-family: var(--font-main);
    font-size: 13px;
    line-height: 1.5;
    resize: none;
    max-height: 100px;
    padding: 6px 0;
}

#message-input::placeholder {
    color: var(--text-muted);
}

.input-actions {
    display: flex;
    gap: 4px;
    align-items: center;
}

.input-btn {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: none;
    background: transparent;
    color: var(--text-muted);
    font-size: 14px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s, color 0.15s;
}

.input-btn:hover {
    background: rgba(255, 255, 255, 0.06);
    color: var(--text-secondary);
}

.input-btn.btn-send {
    background: var(--text-primary);
    color: var(--bg-primary);
    font-size: 12px;
}

.input-btn.btn-send:hover {
    opacity: 0.85;
}

.input-btn.btn-send:disabled {
    opacity: 0.25;
    cursor: not-allowed;
}

#input-hint {
    padding: 2px 16px 8px;
    font-size: 11px;
    color: var(--text-muted);
}

#typing-indicator {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--text-muted);
    font-size: 11px;
}

.typing-dot {
    width: 5px;
    height: 5px;
    background: var(--text-muted);
    border-radius: 50%;
    animation: dotPulse 1s ease-in-out infinite;
}

.typing-dot:nth-child(2) {
    animation-delay: 0.15s;
}

.typing-dot:nth-child(3) {
    animation-delay: 0.3s;
}

/* ── Right Sidebar ── */
.sidebar-right {
    width: var(--right-panel-width);
    min-width: var(--right-panel-width);
    background: var(--bg-secondary);
    border-left: 1px solid var(--border-subtle);
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 8px;
    overflow-y: auto;
    transition: width 0.2s ease, min-width 0.2s ease, padding 0.2s ease;
    position: relative;
}

.sidebar-right.collapsed {
    width: 0;
    min-width: 0;
    padding: 0;
    overflow: hidden;
}

.right-toggle {
    position: absolute;
    left: -16px;
    top: 50%;
    transform: translateY(-50%);
    width: 16px;
    height: 40px;
    border: none;
    background: var(--bg-tertiary);
    color: var(--text-muted);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 9px;
    border-radius: 4px 0 0 4px;
    z-index: 5;
    transition: background 0.15s, color 0.15s;
    border: 1px solid var(--border-subtle);
    border-right: none;
}

.right-toggle:hover {
    background: var(--bg-card);
    color: var(--text-secondary);
}

.sidebar-right.collapsed .right-toggle span {
    transform: rotate(180deg);
    display: inline-block;
}

/* ── Context Cards ── */
.context-card {
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-sm);
    overflow: hidden;
    flex-shrink: 0;
}

.card-header {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 8px 12px;
    border-bottom: 1px solid var(--border-subtle);
    background: var(--bg-tertiary);
}

.card-icon {
    font-size: 12px;
    opacity: 0.8;
}

.card-title {
    font-size: 10px;
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.card-content {
    padding: 10px 12px;
}

/* ── Session Stats ── */
.session-stat {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 4px 0;
    font-size: 12px;
}

.session-stat .stat-label {
    color: var(--text-muted);
}

.session-stat .stat-value {
    color: var(--text-primary);
    font-weight: 500;
}

/* ── System Status ── */
.system-status-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
}

.status-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.status-label {
    font-size: 11px;
    color: var(--text-muted);
}

.status-value {
    font-size: 11px;
    color: var(--success);
}

.status-ok {
    color: var(--success);
}

.status-offline {
    color: var(--text-muted);
}

/* ── Activity List ── */
.activity-list {
    display: flex;
    flex-direction: column;
    gap: 6px;
}

.activity-item {
    display: flex;
    gap: 8px;
    font-size: 11px;
}

.activity-time {
    color: var(--text-muted);
    flex-shrink: 0;
    min-width: 40px;
    font-size: 10px;
}

.activity-text {
    color: var(--text-secondary);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
}

/* ── Empty State ── */
.empty-view {
    text-align: center;
    padding: 40px 20px;
    color: var(--text-muted);
    font-size: 13px;
}

/* ── Tasks Grid ── */
.tasks-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 10px;
}

.task-card {
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-sm);
    padding: 14px;
    transition: border-color 0.15s;
}

.task-card:hover {
    border-color: var(--border-hover);
}

.task-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 6px;
}

.task-title {
    font-size: 13px;
    font-weight: 500;
    color: var(--text-primary);
}

.task-status {
    font-size: 10px;
    padding: 2px 8px;
    border-radius: 10px;
    text-transform: uppercase;
    letter-spacing: 0.3px;
    border: 1px solid var(--border-subtle);
}

.task-status.active {
    background: rgba(255, 255, 255, 0.06);
    color: var(--text-primary);
    border-color: var(--text-muted);
}

.task-status.completed {
    background: rgba(34, 197, 94, 0.08);
    color: var(--success);
    border-color: rgba(34, 197, 94, 0.2);
}

.task-deadline {
    font-size: 11px;
    color: var(--text-muted);
    margin-bottom: 8px;
}

.task-actions {
    display: flex;
    gap: 6px;
}

.task-btn {
    padding: 5px 10px;
    border: 1px solid var(--border-subtle);
    background: transparent;
    border-radius: 4px;
    font-size: 11px;
    cursor: pointer;
    color: var(--text-muted);
    font-family: var(--font-main);
    transition: border-color 0.15s, background 0.15s, color 0.15s;
}

.task-btn:hover {
    border-color: var(--border-hover);
    color: var(--text-secondary);
}

.task-btn.complete {
    color: var(--success);
}

.task-btn.complete:hover {
    background: rgba(34, 197, 94, 0.08);
    border-color: var(--success);
}

.task-btn.delete:hover {
    background: rgba(239, 68, 68, 0.08);
    border-color: var(--error);
    color: var(--error);
}

/* ── Systems Grid ── */
.systems-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
}

.system-card {
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-sm);
    padding: 16px;
    transition: border-color 0.15s;
}

.system-card:hover {
    border-color: var(--border-hover);
}

.sys-header {
    font-size: 13px;
    font-weight: 600;
    margin-bottom: 6px;
    color: var(--text-primary);
}

.sys-status {
    font-size: 12px;
    margin-bottom: 6px;
}

.sys-status.status-ok {
    color: var(--success);
}

.sys-detail {
    font-size: 11px;
    color: var(--text-muted);
}

/* ── Analytics Grid ── */
.analytics-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
}

.analytics-card {
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-sm);
    padding: 20px;
    text-align: center;
    transition: border-color 0.15s;
}

.analytics-card:hover {
    border-color: var(--border-hover);
}

.analytics-value {
    display: block;
    font-size: 32px;
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1.2;
}

.analytics-label {
    display: block;
    font-size: 11px;
    color: var(--text-muted);
    margin-top: 6px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

/* ── Logs ── */
.logs-container {
    flex: 1;
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-sm);
    padding: 12px;
    overflow-y: auto;
    font-family: var(--font-mono);
    font-size: 11px;
    line-height: 1.6;
    max-height: 400px;
}

.logs-container div {
    color: var(--text-secondary);
    border-bottom: 1px solid var(--border-subtle);
    padding: 3px 0;
}

/* ── Settings ── */
.settings-panel-inline {
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-sm);
    padding: 16px;
    max-width: 500px;
}

.setting-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px 0;
    border-bottom: 1px solid var(--border-subtle);
    font-size: 13px;
}

.setting-row span:first-child {
    color: var(--text-secondary);
}

.setting-row span:last-child {
    color: var(--text-primary);
    font-weight: 500;
}

/* ── Calendar ── */
.calendar-content {
    flex: 1;
}

.calendar-header {
    display: flex;
    justify-content: center;
    margin-bottom: 16px;
}

.calendar-title {
    font-size: 16px;
    font-weight: 600;
    color: var(--text-primary);
}

.calendar-weekdays {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 3px;
    margin-bottom: 6px;
}

.calendar-weekdays > div {
    text-align: center;
    font-size: 10px;
    font-weight: 600;
    color: var(--text-muted);
    padding: 6px 0;
    text-transform: uppercase;
    letter-spacing: 0.3px;
}

.calendar-days {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 3px;
}

.calendar-day {
    min-height: 60px;
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-sm);
    padding: 6px;
    transition: border-color 0.15s;
}

.calendar-day:hover {
    border-color: var(--border-hover);
}

.calendar-day.empty {
    background: transparent;
    border: none;
}

.calendar-day.today {
    border-color: var(--text-primary);
    background: rgba(255, 255, 255, 0.03);
}

.calendar-day.has-goals {
    border-color: var(--warning);
}

.day-number {
    font-size: 12px;
    font-weight: 600;
    color: var(--text-secondary);
}

.calendar-day.today .day-number {
    color: var(--text-primary);
}

.day-goal {
    font-size: 9px;
    color: var(--text-secondary);
    background: var(--bg-tertiary);
    padding: 1px 5px;
    border-radius: 3px;
    margin-top: 3px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    border: 1px solid var(--border-subtle);
}

.day-more {
    font-size: 9px;
    color: var(--text-muted);
    margin-top: 3px;
}

/* ── Client Cards ── */
.clients-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 12px;
}

.client-card {
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-sm);
    padding: 14px;
    transition: border-color 0.15s;
}

.client-card:hover {
    border-color: var(--border-hover);
}

.client-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 10px;
}

.client-avatar {
    width: 36px;
    height: 36px;
    background: var(--bg-tertiary);
    border: 1px solid var(--border-subtle);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 500;
    font-size: 14px;
    color: var(--text-primary);
    flex-shrink: 0;
}

.client-info {
    flex: 1;
    min-width: 0;
}

.client-name {
    font-size: 14px;
    font-weight: 600;
    color: var(--text-primary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.client-email {
    font-size: 11px;
    color: var(--text-muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.client-status {
    font-size: 10px;
    padding: 2px 8px;
    border-radius: 10px;
    text-transform: uppercase;
    letter-spacing: 0.3px;
}

.client-status.active {
    background: rgba(34, 197, 94, 0.08);
    color: var(--success);
    border: 1px solid rgba(34, 197, 94, 0.2);
}

.client-meta {
    font-size: 11px;
    color: var(--text-secondary);
    display: flex;
    flex-direction: column;
    gap: 3px;
    margin-bottom: 10px;
}

.client-actions {
    display: flex;
    gap: 6px;
}

/* ── Lead Kanban ── */
.leads-kanban {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 10px;
    min-height: 250px;
}

.lead-column {
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-sm);
    display: flex;
    flex-direction: column;
}

.lead-column-header {
    padding: 10px 12px;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    border-bottom: 1px solid var(--border-subtle);
    background: var(--bg-tertiary);
    border-radius: var(--radius-sm) var(--radius-sm) 0 0;
}

.lead-column[data-stage="cold"] .lead-column-header {
    color: var(--info);
}

.lead-column[data-stage="warm"] .lead-column-header {
    color: var(--warning);
}

.lead-column[data-stage="hot"] .lead-column-header {
    color: var(--error);
}

.lead-column[data-stage="converted"] .lead-column-header {
    color: var(--success);
}

.lead-column-body {
    flex: 1;
    padding: 8px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    overflow-y: auto;
    max-height: 350px;
}

.lead-card {
    background: var(--bg-secondary);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-sm);
    padding: 10px;
    transition: border-color 0.15s;
}

.lead-card:hover {
    border-color: var(--border-hover);
}

.lead-name {
    font-size: 12px;
    font-weight: 600;
    margin-bottom: 3px;
    color: var(--text-primary);
}

.lead-company {
    font-size: 10px;
    color: var(--text-muted);
    margin-bottom: 4px;
}

.lead-value {
    font-size: 13px;
    font-weight: 700;
    color: var(--success);
    margin-bottom: 6px;
}

.lead-actions {
    display: flex;
    gap: 4px;
}

.lead-actions button {
    padding: 3px 6px;
    border: 1px solid var(--border-subtle);
    background: transparent;
    border-radius: 3px;
    font-size: 10px;
    cursor: pointer;
    color: var(--text-muted);
    font-family: var(--font-main);
    transition: border-color 0.15s, color 0.15s;
}

.lead-actions button:hover {
    border-color: var(--border-hover);
    color: var(--text-primary);
}

/* ── Modals ── */
.modal {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.7);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1000;
    backdrop-filter: blur(2px);
}

.modal.hidden {
    display: none !important;
}

.modal-content {
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-md);
    width: 100%;
    max-width: 420px;
    box-shadow: var(--shadow-modal);
}

.modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 18px;
    border-bottom: 1px solid var(--border-subtle);
}

.modal-header h3 {
    font-size: 15px;
    font-weight: 600;
    color: var(--text-primary);
}

.modal-close {
    background: transparent;
    border: none;
    color: var(--text-muted);
    font-size: 16px;
    cursor: pointer;
    transition: color 0.15s;
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 4px;
}

.modal-close:hover {
    color: var(--error);
    background: rgba(239, 68, 68, 0.08);
}

.modal-body {
    padding: 18px;
}

.modal-footer {
    display: flex;
    justify-content: flex-end;
    gap: 10px;
    padding: 14px 18px;
    border-top: 1px solid var(--border-subtle);
}

/* ── Form Groups ── */
.form-group {
    margin-bottom: 14px;
}

.form-group label {
    display: block;
    font-size: 11px;
    font-weight: 500;
    color: var(--text-muted);
    margin-bottom: 5px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.form-group input,
.form-group textarea,
.form-group select {
    width: 100%;
    padding: 8px 12px;
    background: var(--bg-input);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-sm);
    color: var(--text-primary);
    font-size: 13px;
    font-family: var(--font-main);
    transition: border-color 0.15s;
    outline: none;
}

.form-group input:focus,
.form-group textarea:focus,
.form-group select:focus {
    border-color: var(--text-muted);
}

.form-group textarea {
    resize: vertical;
    min-height: 60px;
}

.form-group select {
    cursor: pointer;
}

.form-group select option {
    background: var(--bg-secondary);
}

/* ── Legacy Sidebar Elements (orion-theme compat) ── */
.sidebar-header {
    padding: 16px;
    border-bottom: 1px solid var(--border-subtle);
}

.new-chat-btn {
    width: 100%;
    padding: 10px 16px;
    background: transparent;
    border: 1px dashed var(--border-subtle);
    color: var(--text-secondary);
    border-radius: var(--radius-sm);
    cursor: pointer;
    font-family: var(--font-main);
    font-size: 13px;
    font-weight: 500;
    display: flex;
    align-items: center;
    gap: 8px;
    transition: border-color 0.15s, color 0.15s;
}

.new-chat-btn:hover {
    border-color: var(--text-muted);
    color: var(--text-primary);
    background: rgba(255, 255, 255, 0.03);
}

.btn-icon {
    font-size: 18px;
    font-weight: 300;
    line-height: 1;
}

.sidebar-section {
    padding: 12px 16px;
    flex: 1;
    overflow-y: auto;
}

.sidebar-title {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--text-muted);
    margin-bottom: 8px;
    font-weight: 600;
}

.nav-list {
    display: flex;
    flex-direction: column;
    gap: 2px;
}

/* Backward-compat nav-item (no data-view attr) */
.nav-item:not([data-view]) {
    display: flex;
    align-items: center;
    gap: 8px;
    width: 100%;
    padding: 8px 12px;
    font-size: 13px;
    border: none;
    background: transparent;
    cursor: pointer;
    border-radius: var(--radius-sm);
    transition: background 0.15s, color 0.15s;
    color: var(--text-secondary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.nav-item:not([data-view]):hover {
    background: rgba(255, 255, 255, 0.04);
    color: var(--text-primary);
}

.nav-item:not([data-view]).active {
    background: rgba(255, 255, 255, 0.06);
    color: var(--text-primary);
    border-left: 2px solid var(--text-primary);
    padding-left: 10px;
}

.version-info {
    font-size: 10px;
    color: var(--text-muted);
    text-align: center;
    margin-top: 8px;
}

.action-btn {
    width: 100%;
    padding: 8px 12px;
    margin-bottom: 6px;
    background: transparent;
    border: 1px solid var(--border-subtle);
    color: var(--text-secondary);
    border-radius: var(--radius-sm);
    cursor: pointer;
    font-family: var(--font-main);
    font-size: 12px;
    text-align: left;
    transition: border-color 0.15s, color 0.15s, background 0.15s;
}

.action-btn:hover {
    background: rgba(255, 255, 255, 0.04);
    color: var(--text-primary);
    border-color: var(--border-hover);
}

/* ── Sidebar Search ── */
.sidebar-search {
    padding: 12px;
    border-bottom: 1px solid var(--border-subtle);
}

.sidebar-search input {
    width: 100%;
    padding: 8px 12px;
    background: var(--bg-input);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-sm);
    color: var(--text-primary);
    font-size: 13px;
    outline: none;
    transition: border-color 0.15s;
}

.sidebar-search input:focus {
    border-color: var(--text-muted);
}

.sidebar-search input::placeholder {
    color: var(--text-muted);
}

/* ── Section Headers ── */
.section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 8px 12px;
}

.section-header .sidebar-title {
    margin: 0;
}

.icon-btn {
    width: 24px;
    height: 24px;
    border: none;
    background: var(--bg-tertiary);
    border-radius: var(--radius-sm);
    color: var(--text-muted);
    cursor: pointer;
    font-size: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s, color 0.15s;
}

.icon-btn:hover {
    background: var(--bg-elevated);
    color: var(--text-primary);
}

/* ── Folders ── */
.folders-list {
    padding: 8px;
}

.folder-item {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 10px;
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition: background 0.15s;
    margin-bottom: 4px;
}

.folder-item:hover {
    background: rgba(255, 255, 255, 0.04);
}

.folder-item.active {
    background: rgba(255, 255, 255, 0.06);
    border-left: 2px solid var(--text-primary);
    padding-left: 8px;
}

.folder-item .folder-icon {
    font-size: 16px;
    opacity: 0.8;
}

.folder-item .folder-name {
    flex: 1;
    font-size: 13px;
    color: var(--text-secondary);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
}

.folder-item .folder-actions {
    opacity: 0;
    transition: opacity 0.15s;
    display: flex;
    gap: 4px;
}

.folder-item:hover .folder-actions {
    opacity: 1;
}

/* ── Project Item (Legacy) ── */
.project-item {
    margin-bottom: 8px;
}

.project-header {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 12px;
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition: background 0.15s;
}

.project-header:hover {
    background: rgba(255, 255, 255, 0.04);
}

.project-expand {
    font-size: 10px;
    transition: transform 0.2s;
    display: inline-block;
    color: var(--text-muted);
}

.project-header.expanded .project-expand {
    transform: rotate(90deg);
}

.project-chats {
    padding-left: 20px;
    display: none;
}

.project-item.expanded .project-chats {
    display: block;
}

/* ── Text Button ── */
.text-btn {
    background: none;
    border: none;
    color: var(--text-muted);
    font-size: 12px;
    cursor: pointer;
    padding: 8px 12px;
    text-decoration: underline;
    text-underline-offset: 2px;
    font-family: var(--font-main);
    transition: color 0.15s;
}

.text-btn:hover {
    color: var(--text-primary);
}

/* ── Quick Actions (Theme compat) ── */
.quick-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    justify-content: center;
}

.quick-action-btn {
    padding: 12px 20px;
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    color: var(--text-primary);
    border-radius: var(--radius-sm);
    cursor: pointer;
    font-family: var(--font-main);
    font-size: 13px;
    display: flex;
    align-items: center;
    gap: 8px;
    transition: border-color 0.15s, background 0.15s;
    min-width: 140px;
}

.quick-action-btn:hover {
    border-color: var(--text-muted);
    background: var(--bg-surface);
}

.action-icon {
    font-size: 20px;
    opacity: 0.9;
}

/* ── Welcome Section ── */
.welcome-section {
    text-align: center;
    position: relative;
    z-index: 1;
}

.welcome-section h1 {
    font-size: 36px;
    font-weight: 700;
    margin-bottom: 8px;
    color: var(--text-primary);
    letter-spacing: 2px;
}

.subtitle {
    color: var(--text-secondary);
    font-size: 16px;
    margin-bottom: 30px;
    font-weight: 400;
}

.hologram-effect {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, rgba(255, 255, 255, 0.03) 0%, transparent 70%);
    pointer-events: none;
}

/* ── Performance: Disable animations during resize ── */
body.resizing * {
    animation: none !important;
    transition: none !important;
}

/* ── Dashboard hero welcome section (legacy compat) ── */
.dashboard-hero .welcome-section {
    margin-bottom: 0;
}
