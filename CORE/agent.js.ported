/**
 * ORION — Base Agent Class
 * All sub-agents extend this. Handles identity, prompts, tools, and execution.
 * Uses Ollama as primary brain, with cloud fallback.
 */

const fs = require('fs');
const path = require('path');

class Agent {
    constructor(config) {
        this.id = config.id;
        this.name = config.name;
        this.description = config.description;
        this.systemPrompt = config.systemPrompt;
        this.tools = config.tools || [];
        this.status = 'idle';
        this.currentTask = null;
        this.taskHistory = [];
    }

    /**
     * Execute a task
     */
    async execute(task, settings, personality, brain, ollamaBrain) {
        this.status = 'working';
        this.currentTask = task;
        this.taskHistory.push({ task, timestamp: new Date().toISOString(), status: 'started' });

        try {
            const result = await this._callLLM(task, settings, ollamaBrain);
            this.status = 'idle';
            this.currentTask = null;
            this._logTask(task, 'completed', result);
            return result;
        } catch (err) {
            this.status = 'error';
            this.currentTask = null;
            this._logTask(task, 'error', err.message);
            throw err;
        }
    }

    /**
     * LLM call — Ollama first, then cloud fallback
     */
    async _callLLM(task, settings, ollamaBrain) {
        const messages = [
            { role: 'system', content: this.systemPrompt },
            { role: 'user', content: task }
        ];

        // Try Ollama first
        if (ollamaBrain?.available) {
            try {
                return await this._ollamaRequest(messages, ollamaBrain, settings);
            } catch (err) {
                console.log(`[Agent:${this.name}] Ollama failed, falling back to cloud: ${err.message}`);
            }
        }

        // Cloud fallback
        return await this._cloudRequest(messages, settings);
    }

    /**
     * Get the best model for this agent type
     */
    _getOllamaModel(settings) {
        const models = settings.ollama?.models || {};
        switch (this.id) {
            case 'coder':
                return models.coder || 'qwen2.5-coder:7b';
            case 'scheduler':
                return models.fast || 'qwen2.5-coder:1.5b'; // Scheduler doesn't need heavy model
            case 'business':
                return models.manager || 'qwen3:8b';
            default:
                return models.manager || 'qwen3:8b';
        }
    }

    async _ollamaRequest(messages, ollamaBrain, settings) {
        const model = this._getOllamaModel(settings);
        return await ollamaBrain.chat(messages, model);
    }

    async _cloudRequest(messages, settings) {
        // Groq first (fastest cloud)
        if (settings.groq?.apiKey && !settings.groq.apiKey.includes('PASTE')) {
            try {
                return await this._groqRequest(messages, settings.groq);
            } catch (err) {
                console.log(`[Agent:${this.name}] Groq failed: ${err.message}`);
            }
        }
        // OpenRouter — try Claude first, then Grok
        if (settings.openrouter) {
            if (settings.openrouter.claudeKey && !settings.openrouter.claudeKey.includes('PASTE')) {
                try {
                    return await this._openRouterRequest(messages, settings.openrouter, 'claude');
                } catch (err) {
                    console.log(`[Agent:${this.name}] OpenRouter Claude failed: ${err.message}`);
                }
            }
            if (settings.openrouter.grokKey && !settings.openrouter.grokKey.includes('PASTE')) {
                try {
                    return await this._openRouterRequest(messages, settings.openrouter, 'grok');
                } catch (err) {
                    console.log(`[Agent:${this.name}] OpenRouter Grok failed: ${err.message}`);
                }
            }
        }
        // Gemini last
        if (settings.gemini?.apiKey && !settings.gemini.apiKey.includes('PASTE')) {
            try {
                return await this._geminiRequest(messages, settings.gemini);
            } catch (err) {
                console.log(`[Agent:${this.name}] Gemini failed: ${err.message}`);
            }
        }
        throw new Error('All cloud brains unavailable');
    }

    async _groqRequest(messages, groqConfig) {
        const controller = new AbortController();
        const timeout = setTimeout(() => controller.abort(), 30000);

        try {
            const response = await fetch('https://api.groq.com/openai/v1/chat/completions', {
                method: 'POST',
                headers: {
                    'Authorization': `Bearer ${groqConfig.apiKey}`,
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({ model: groqConfig.model || 'llama-3.3-70b-versatile', messages, stream: false }),
                signal: controller.signal
            });

            clearTimeout(timeout);

            if (!response.ok) {
                const err = await response.json();
                throw new Error(err.error?.message || `Groq Error: ${response.status}`);
            }

            const data = await response.json();
            return data.choices[0].message.content;
        } catch (err) {
            clearTimeout(timeout);
            if (err.name === 'AbortError') throw new Error('Groq timed out');
            throw err;
        }
    }

    async _openRouterRequest(messages, openrouterConfig, type) {
        const controller = new AbortController();
        const timeout = setTimeout(() => controller.abort(), 45000);

        const apiKey = type === 'grok' ? openrouterConfig.grokKey : openrouterConfig.claudeKey;
        const model = type === 'grok'
            ? (openrouterConfig.grokModel || 'xai/grok-2')
            : (openrouterConfig.claudeModel || 'anthropic/claude-3.5-sonnet');

        try {
            const response = await fetch('https://openrouter.ai/api/v1/chat/completions', {
                method: 'POST',
                headers: {
                    'Authorization': `Bearer ${apiKey}`,
                    'HTTP-Referer': 'https://orion.local',
                    'X-Title': 'ORION',
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({ model, messages, stream: false }),
                signal: controller.signal
            });

            clearTimeout(timeout);

            if (!response.ok) {
                const err = await response.json();
                throw new Error(err.error?.message || `OpenRouter Error: ${response.status}`);
            }

            const data = await response.json();
            return data.choices[0].message.content;
        } catch (err) {
            clearTimeout(timeout);
            if (err.name === 'AbortError') throw new Error('OpenRouter timed out');
            throw err;
        }
    }

    async _geminiRequest(messages, geminiConfig) {
        const controller = new AbortController();
        const timeout = setTimeout(() => controller.abort(), 30000);

        const model = 'gemini-2.0-flash';
        const url = `https://generativelanguage.googleapis.com/v1beta/models/${model}:generateContent?key=${geminiConfig.apiKey}`;

        const systemContent = messages.find(m => m.role === 'system')?.content || '';
        const userContent = messages.map(m => m.role === 'user' ? m.content : '').join('\n');

        try {
            const response = await fetch(url, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    systemInstruction: { parts: [{ text: systemContent }] },
                    contents: [{ parts: [{ text: userContent }] }]
                }),
                signal: controller.signal
            });

            clearTimeout(timeout);

            if (!response.ok) {
                throw new Error(`Gemini Error: ${response.statusText}`);
            }

            const data = await response.json();
            return data.candidates[0].content.parts[0].text;
        } catch (err) {
            clearTimeout(timeout);
            if (err.name === 'AbortError') throw new Error('Gemini timed out');
            throw err;
        }
    }

    _logTask(task, status, result) {
        this.taskHistory.push({
            task: task.substring(0, 200),
            status,
            result: typeof result === 'string' ? result.substring(0, 500) : '',
            timestamp: new Date().toISOString()
        });
    }

    getInfo() {
        return {
            id: this.id,
            name: this.name,
            description: this.description,
            status: this.status,
            currentTask: this.currentTask,
            tasksCompleted: this.taskHistory.filter(t => t.status === 'completed').length
        };
    }
}

module.exports = Agent;
