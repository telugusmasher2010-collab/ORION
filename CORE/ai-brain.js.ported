/**
 * ORION — AI Brain v2 (Multi-Brain Manager)
 * Routes to Ollama (local) or Cloud (Groq/OpenRouter/Gemini) based on task type.
 * Local-first for code, planning, chat. Cloud for internet/research tasks.
 */

const BrainRouter = require('./brain-router');

class AIBrain {
    constructor(settings, personalityEngine, agentRegistry, ollamaBrain) {
        this.settings = settings;
        this.personality = personalityEngine;
        this.agentRegistry = agentRegistry;
        this.ollama = ollamaBrain;
        this.router = new BrainRouter(settings, ollamaBrain);
        this.lastBrainUsed = null;
        this.lastAgentUsed = null;
    }

/**
      * Main chat handler
      */
    async asyncChat(message, conversationHistory = [], onChunk) {
        console.log('[AIBrain] asyncChat called');
        const mode = this.personality.detectMode(message);
        const systemPrompt = this.personality.buildSystemPrompt();

        // Step 1: Check if a sub-agent should handle this
        const agentResult = await this.agentRegistry.executeTask(
            message,
            this.settings,
            this.personality,
            this
        );

        if (agentResult.handled) {
            this.lastAgentUsed = agentResult.agent;
            this.lastBrainUsed = `agent:${agentResult.agent.name}`;

            let response = agentResult.response.response || agentResult.response;

            if (agentResult.response.filesCreated && agentResult.response.filesCreated.length > 0) {
                response += `\n\n[FILES CREATED]\n${agentResult.response.filesCreated.map(f => '  - ' + f).join('\n')}`;
            }

            return {
                response,
                mode: this.personality.getModeDisplay(mode),
                brain: { label: `🤖 ${agentResult.agent.name}`, name: agentResult.agent.name, id: agentResult.agent.id },
                agent: agentResult.agent
            };
        }

        // Step 2: Route to the best brain
        const brainConfig = this.router.route(message);
        console.log(`[AIBrain] Routing to: ${brainConfig.label} (${brainConfig.model})`);

        // Clean conversation history — only send role + content to LLM
        const cleanHistory = conversationHistory.map(h => ({
            role: h.role,
            content: h.content
        }));

        const messages = [
            { role: 'system', content: systemPrompt },
            ...cleanHistory,
            { role: 'user', content: message }
        ];

        let response = '';

        try {
            switch (brainConfig.brain) {
                case 'ollama':
                    response = await this._ollamaStream(messages, brainConfig.model, onChunk);
                    break;
                case 'groq':
                    response = await this._groqStream(messages, brainConfig.model, onChunk);
                    break;
                case 'openrouter-claude':
                    response = await this._openRouterClaudeStream(messages, brainConfig.model, onChunk);
                    break;
                case 'openrouter-grok':
                    response = await this._openRouterGrokStream(messages, brainConfig.model, onChunk);
                    break;
                case 'gemini':
                    response = await this._geminiStream(messages, brainConfig.model, onChunk);
                    break;
                case 'error':
                    throw new Error('No AI brain available. Check settings.json.');
                default:
                    response = await this._groqStream(messages, brainConfig.model, onChunk);
            }

            this.lastBrainUsed = brainConfig.brain;
        } catch (err) {
            console.error(`[AIBrain] ${brainConfig.brain} failed: ${err.message}`);
            // Try fallback
            const fallback = this.router.getFallbackBrain();
            if (fallback.brain !== brainConfig.brain && fallback.brain !== 'error') {
                console.log(`[AIBrain] Falling back to: ${fallback.label}`);
                try {
                    response = await this._executeBrain(fallback, messages, onChunk);
                    this.lastBrainUsed = fallback.brain;
                    brainConfig.label = fallback.label + ' (fallback)';
                } catch (fallbackErr) {
                    throw new Error(`Primary failed: ${err.message}. Fallback also failed: ${fallbackErr.message}`);
                }
            } else {
                throw err;
            }
        }

        return {
            response,
            mode: this.personality.getModeDisplay(mode),
            brain: { label: brainConfig.label, name: brainConfig.brain, id: brainConfig.brain, source: brainConfig.source }
        };
    }

    /**
     * Execute a brain by type — handles format differences
     */
    async _executeBrain(brainConfig, messages, onChunk) {
        switch (brainConfig.brain) {
            case 'groq':
                return await this._groqStream(messages, brainConfig.model, onChunk);
            case 'openrouter-claude':
                return await this._openRouterClaudeStream(messages, brainConfig.model, onChunk);
            case 'openrouter-grok':
                return await this._openRouterGrokStream(messages, brainConfig.model, onChunk);
            case 'gemini':
                return await this._geminiStream(messages, brainConfig.model, onChunk);
            default:
                throw new Error(`Unknown brain: ${brainConfig.brain}`);
        }
    }

    getLastBrainInfo() {
        return {
            brain: this.lastBrainUsed,
            label: this.lastAgentUsed ? `🤖 ${this.lastAgentUsed.name}` : '🧠 Manager',
            name: this.lastAgentUsed?.name || 'Manager',
            id: this.lastAgentUsed?.id || 'manager'
        };
    }

    // ========================================
    // OLLAMA (Local)
    // ========================================
    async _ollamaStream(messages, model, onChunk) {
        const text = await this.ollama.streamChat(messages, model, onChunk);
        this.lastBrainUsed = 'ollama';
        return text;
    }

    // ========================================
    // GROQ (Cloud)
    // ========================================
    async _groqStream(messages, model, onChunk) {
        const apiKey = this.settings.groq.apiKey;
        const controller = new AbortController();
        const timeout = setTimeout(() => controller.abort(), 30000);

        try {
            const response = await fetch('https://api.groq.com/openai/v1/chat/completions', {
                method: 'POST',
                headers: {
                    'Authorization': `Bearer ${apiKey}`,
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({ model, messages, stream: true }),
                signal: controller.signal
            });

            clearTimeout(timeout);

            if (!response.ok) {
                const err = await response.json();
                throw new Error(err.error?.message || `Groq API Error: ${response.status}`);
            }

            if (!response.body || typeof response.body.getReader !== 'function') {
                console.log('[Groq] Streaming body not available, falling back to non-streaming');
                return await this._groqNonStreaming(messages, model, onChunk);
            }

            return await this._readOpenAIStream(response.body, onChunk);
        } catch (err) {
            clearTimeout(timeout);
            if (err.name === 'AbortError') throw new Error('Groq request timed out (30s)');
            console.log('[Groq] Streaming failed, trying non-streaming fallback:', err.message);
            try {
                return await this._groqNonStreaming(messages, model, onChunk);
            } catch (fallbackErr) {
                throw new Error(`Groq failed: ${err.message}`);
            }
        }
    }

    async _groqNonStreaming(messages, model, onChunk) {
        const apiKey = this.settings.groq.apiKey;
        const controller = new AbortController();
        const timeout = setTimeout(() => controller.abort(), 60000);

        try {
            const response = await fetch('https://api.groq.com/openai/v1/chat/completions', {
                method: 'POST',
                headers: {
                    'Authorization': `Bearer ${apiKey}`,
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({ model, messages, stream: false }),
                signal: controller.signal
            });

            clearTimeout(timeout);

            if (!response.ok) {
                const err = await response.json();
                throw new Error(err.error?.message || `Groq API Error: ${response.status}`);
            }

            const data = await response.json();
            const text = data.choices?.[0]?.message?.content || '';
            if (text && onChunk) onChunk(text);
            return text;
        } catch (err) {
            clearTimeout(timeout);
            if (err.name === 'AbortError') throw new Error('Groq request timed out (60s)');
            throw err;
        }
    }

    // ========================================
    // OpenRouter — Claude
    // ========================================
    async _openRouterClaudeStream(messages, model, onChunk) {
        const apiKey = this.settings.openrouter.claudeKey;
        const controller = new AbortController();
        const timeout = setTimeout(() => controller.abort(), 45000); // 45s timeout for Claude

        try {
            const response = await fetch('https://openrouter.ai/api/v1/chat/completions', {
                method: 'POST',
                headers: {
                    'Authorization': `Bearer ${apiKey}`,
                    'HTTP-Referer': 'https://orion.local',
                    'X-Title': 'ORION',
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({ model, messages, stream: true }),
                signal: controller.signal
            });

            clearTimeout(timeout);

            if (!response.ok) {
                const err = await response.json();
                throw new Error(err.error?.message || `OpenRouter Claude Error: ${response.status}`);
            }

            return await this._readOpenAIStream(response.body, onChunk);
        } catch (err) {
            clearTimeout(timeout);
            if (err.name === 'AbortError') throw new Error('OpenRouter Claude request timed out (45s)');
            throw err;
        }
    }

    // ========================================
    // OpenRouter — Grok (xAI)
    // ========================================
    async _openRouterGrokStream(messages, model, onChunk) {
        const apiKey = this.settings.openrouter.grokKey;
        const controller = new AbortController();
        const timeout = setTimeout(() => controller.abort(), 45000);

        try {
            const response = await fetch('https://openrouter.ai/api/v1/chat/completions', {
                method: 'POST',
                headers: {
                    'Authorization': `Bearer ${apiKey}`,
                    'HTTP-Referer': 'https://orion.local',
                    'X-Title': 'ORION',
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({ model, messages, stream: true }),
                signal: controller.signal
            });

            clearTimeout(timeout);

            if (!response.ok) {
                const err = await response.json();
                throw new Error(err.error?.message || `OpenRouter Grok Error: ${response.status}`);
            }

            return await this._readOpenAIStream(response.body, onChunk);
        } catch (err) {
            clearTimeout(timeout);
            if (err.name === 'AbortError') throw new Error('OpenRouter Grok request timed out (45s)');
            throw err;
        }
    }

    // ========================================
    // Gemini (Google)
    // ========================================
    async _geminiStream(messages, model, onChunk) {
        const apiKey = this.settings.gemini.apiKey;
        const controller = new AbortController();
        const timeout = setTimeout(() => controller.abort(), 30000);

        try {
            const url = `https://generativelanguage.googleapis.com/v1beta/models/${model}:streamGenerateContent?alt=sse&key=${apiKey}`;

            // Gemini needs special format — flatten to single content block
            const systemContent = messages.find(m => m.role === 'system')?.content || '';
            const userParts = messages
                .filter(m => m.role === 'user' || m.role === 'assistant')
                .map(m => ({ role: m.role, text: m.content }));

            const response = await fetch(url, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    systemInstruction: { parts: [{ text: systemContent }] },
                    contents: [{ parts: userParts.map(p => ({ text: p.text })) }]
                }),
                signal: controller.signal
            });

            clearTimeout(timeout);

            if (!response.ok) throw new Error(`Gemini API Error: ${response.status}`);

            const reader = response.body.getReader();
            let fullText = '';

            while (true) {
                const { done, value } = await reader.read();
                if (done) break;

                const chunk = new TextDecoder().decode(value);
                const lines = chunk.split('\n');

                for (const line of lines) {
                    if (line.startsWith('data: ')) {
                        try {
                            const json = JSON.parse(line.substring(6));
                            const text = json.candidates[0].content.parts[0].text;
                            if (text) {
                                fullText += text;
                                if (onChunk) onChunk(text);
                            }
                        } catch (e) { }
                    }
                }
            }

            this.lastBrainUsed = 'gemini';
            return fullText;
        } catch (err) {
            clearTimeout(timeout);
            if (err.name === 'AbortError') throw new Error('Gemini request timed out (30s)');
            throw err;
        }
    }

    // ========================================
    // Shared OpenAI-compatible stream reader
    // ========================================
    async _readOpenAIStream(body, onChunk) {
        const reader = body.getReader();
        let fullText = '';
        let buffer = '';

        while (true) {
            const { done, value } = await reader.read();
            if (done) break;

            buffer += new TextDecoder().decode(value);
            const lines = buffer.split('\n');
            buffer = lines.pop() || ''; // Keep incomplete line in buffer

            for (const line of lines) {
                const trimmed = line.trim();
                if (!trimmed) continue;

                // Handle both "data: " prefix and raw JSON (OpenRouter sometimes sends without prefix)
                let data = trimmed;
                if (trimmed.startsWith('data: ')) {
                    data = trimmed.substring(6);
                }

                if (data === '[DONE]') continue;

                try {
                    const json = JSON.parse(data);
                    const text = json.choices?.[0]?.delta?.content;
                    if (text) {
                        fullText += text;
                        if (onChunk) onChunk(text);
                    }
                    // Check for error in response
                    if (json.error) {
                        throw new Error(json.error.message || 'Stream error');
                    }
                } catch (e) {
                    if (e.message && e.message !== 'Stream error') {
                        // Skip malformed JSON lines (common in SSE streams)
                    } else {
                        throw e;
                    }
                }
            }
        }

        return fullText;
    }
}

module.exports = AIBrain;
